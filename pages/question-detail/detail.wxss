.detail {
  padding: 16px;
}

.original {
  width: 100%;
  border-radius: 8px;
  margin-bottom: 16px;
}

.field {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.label {
  font-size: 13px;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.field picker {
  font-size: 16px;
  color: #333;
}

.field textarea {
  width: 100%;
  min-height: 100px;
  font-size: 14px;
  color: #333;
  line-height: 1.6;
}

.review-context {
  background: #fff8e1;
}

.review-row {
  margin-top: 8px;
  color: #333;
  font-size: 14px;
  line-height: 1.6;
}

.review-name {
  display: block;
  color: #8d6e63;
  font-size: 12px;
}

.uncertain {
  display: inline-block;
  margin: 4px 6px 0 0;
  padding: 2px 6px;
  border-radius: 4px;
  color: #c62828;
  background: #ffebee;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.tag {
  font-size: 12px;
  color: #1976d2;
  background: #e3f2fd;
  padding: 2px 8px;
  border-radius: 4px;
  margin-right: 6px;
  margin-bottom: 4px;
}

.tags input {
  font-size: 14px;
  color: #333;
  border-bottom: 1px solid #ddd;
  padding: 4px 0;
  min-width: 80px;
}

.field slider {
  width: 100%;
}

button {
  width: 100%;
  background: #1aad19;
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  padding: 12px;
  margin-bottom: 12px;
}

button.danger {
  background: #e53935;
}
