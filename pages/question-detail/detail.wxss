.detail {
  padding: 16px;
}

.question-image-card {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.image-title {
  display: block;
  margin-bottom: 10px;
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.question-image {
  width: 100%;
  border-radius: 8px;
  background: #f5f5f5;
}

.image-state {
  min-height: 160px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  color: #999;
  background: #f5f5f5;
}

.image-error {
  color: #c62828;
  background: #fff5f5;
}

.image-retry {
  width: auto;
  margin: 12px 0 0;
  padding: 4px 16px;
  border: 1px solid #1aad19;
  border-radius: 6px;
  color: #1aad19;
  background: #fff;
  font-size: 13px;
  line-height: 1.8;
}

.image-hint {
  display: block;
  margin-top: 8px;
  text-align: center;
  color: #888;
  font-size: 12px;
}

.localization-notice {
  display: block;
  margin-top: 8px;
  padding: 8px;
  border-radius: 6px;
  color: #8d6e63;
  background: #fff8e1;
  font-size: 12px;
  line-height: 1.5;
}

.field {
  background: #fff;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.06);
}

.label {
  font-size: 13px;
  color: #999;
  display: block;
  margin-bottom: 8px;
}

.field picker {
  font-size: 16px;
  color: #333;
}

.field textarea {
  width: 100%;
  min-height: 100px;
  font-size: 14px;
  color: #333;
  line-height: 1.6;
}

.review-context {
  background: #fff8e1;
}

.review-row {
  margin-top: 8px;
  color: #333;
  font-size: 14px;
  line-height: 1.6;
}

.review-name {
  display: block;
  color: #8d6e63;
  font-size: 12px;
}

.uncertain {
  display: inline-block;
  margin: 4px 6px 0 0;
  padding: 2px 6px;
  border-radius: 4px;
  color: #c62828;
  background: #ffebee;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.tag {
  font-size: 12px;
  color: #1976d2;
  background: #e3f2fd;
  padding: 2px 8px;
  border-radius: 4px;
  margin-right: 6px;
  margin-bottom: 4px;
}

.tags input {
  font-size: 14px;
  color: #333;
  border-bottom: 1px solid #ddd;
  padding: 4px 0;
  min-width: 80px;
}

.difficulty-stars {
  display: flex;
  align-items: center;
}

.difficulty-star {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d8d8d8;
  font-size: 32px;
  line-height: 44px;
}

.difficulty-star.active {
  color: #f5a623;
}

.difficulty-value {
  display: block;
  color: #666;
  font-size: 13px;
}

button {
  width: 100%;
  background: #1aad19;
  color: #fff;
  border-radius: 8px;
  font-size: 16px;
  padding: 12px;
  margin-bottom: 12px;
}

button.danger {
  background: #e53935;
}
