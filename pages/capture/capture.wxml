<view class="capture">
  <view class="info-bar">
    📖 {{grades[gradeIndex]}} · {{semesters[semester]}}
  </view>

  <view class="camera-area" bindtap="takePhoto">
    <image wx:if="{{previewUrl}}" src="{{previewUrl}}" mode="widthFix" />
    <view wx:else class="placeholder">点击拍照或选择图片</view>
  </view>

  <view class="upload-list" wx:if="{{uploads.length > 0}}">
    <view class="upload-item" wx:for="{{uploads}}" wx:key="id">
      <text class="upload-page">📄 第{{index+1}}页</text>
      <text class="status upload-status status-{{item.status}}">{{statusText[item.status]}}</text>
      <text class="subject-tag" bindtap="onSubjectTap" data-index="{{index}}">
        {{item.subject ? (subjectMap[item.subject] || item.subject) : '点击选择科目'}}
      </text>
    </view>
  </view>

  <button class="submit-btn" bindtap="submitAll" disabled="{{uploading}}">确认提交</button>
</view>
